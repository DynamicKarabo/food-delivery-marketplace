# Server
PORT=3004
NODE_ENV=development

# Database
DATABASE_URL=postgresql://fooddelivery:fooddelivery123@localhost:5432/fooddelivery

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Stripe
